# .env.example — copy to .env and fill in real values
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────
DB_PASSWORD=changeme

# ── API Keys ──────────────────────────────────────────────────────────────
ODDS_API_KEY=
GOALSERVE_API_KEY=
KALSHI_API_KEY=

# ── Trading ───────────────────────────────────────────────────────────────
# Set to "live" only when real capital is deployed.
TRADING_MODE=paper

# ── Dashboard / Grafana ───────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme
