{
  "uid": "mmpp-system-overview",
  "title": "System Overview",
  "tags": ["mmpp"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Active Containers",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        { "expr": "active_match_containers", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "gray", "value": null },
              { "color": "green", "value": 1 },
              { "color": "yellow", "value": 6 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Bankroll (Live)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        { "expr": "bankroll_balance{mode=\"live\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" }
      }
    },
    {
      "id": 3,
      "title": "Bankroll (Paper)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        { "expr": "bankroll_balance{mode=\"paper\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" }
      }
    },
    {
      "id": 4,
      "title": "Total Exposure %",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        { "expr": "total_exposure_ratio * 100", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 30,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Max Drawdown %",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        { "expr": "max_drawdown_pct", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 25,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Match Pipeline",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT match_id, league_id, kickoff_utc, status, trading_mode, EXTRACT(EPOCH FROM (NOW() - updated_at))::int AS seconds_since_update FROM match_schedule WHERE kickoff_utc > NOW() - INTERVAL '24 hours' ORDER BY kickoff_utc DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Today's P&L",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT COALESCE(SUM(realized_pnl), 0) AS pnl FROM positions WHERE status = 'SETTLED' AND created_at::date = CURRENT_DATE",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Open Positions",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT match_id, market_ticker, direction, entry_price, quantity, status, is_paper, entry_time FROM positions WHERE status IN ('OPEN', 'AWAITING_SETTLEMENT') ORDER BY entry_time DESC LIMIT 50",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Alerts Firing",
      "type": "alertlist",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 12 },
      "options": {
        "showOptions": "current",
        "sortOrder": 1,
        "stateFilter": { "firing": true, "pending": true }
      }
    }
  ]
}
