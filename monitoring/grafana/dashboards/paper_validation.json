{
  "uid": "mmpp-paper-validation",
  "title": "Paper Trading Validation",
  "tags": ["mmpp"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-30d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Paper Trades Count",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS count FROM positions WHERE is_paper = true AND status = 'SETTLED'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "green", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Paper Edge Realization",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT CASE WHEN SUM(entry_price * quantity) > 0 THEN SUM(realized_pnl) / SUM(entry_price * quantity) ELSE 0 END AS edge_real FROM positions WHERE is_paper = true AND status = 'SETTLED'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0.6 },
              { "color": "yellow", "value": 1.5 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Paper Max Drawdown",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT max_drawdown_pct FROM bankroll_snapshot WHERE is_paper = true ORDER BY snapshot_time DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Paper Realism Score",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT 0.90 AS realism_score",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0.85 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Paper P&L Curve",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT entry_time AS time, SUM(realized_pnl) OVER (ORDER BY entry_time) AS cumulative_pnl FROM positions WHERE is_paper = true AND status = 'SETTLED' ORDER BY entry_time",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "id": 6,
      "title": "Fill Delay Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT EXTRACT(EPOCH FROM (exit_time - entry_time)) AS fill_delay FROM positions WHERE is_paper = true AND exit_time IS NOT NULL",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Partial Fill Rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 12 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) FILTER (WHERE quantity < 100)::float / NULLIF(COUNT(*), 0) AS partial_rate FROM positions WHERE is_paper = true AND status = 'SETTLED'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "id": 8,
      "title": "Slippage Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 12 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT ABS(entry_price - exit_price) * 100 AS slippage_cents FROM positions WHERE is_paper = true AND exit_price IS NOT NULL AND status = 'SETTLED'",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Graduation Checklist",
      "type": "stat",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 20 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT (SELECT COUNT(*) FROM positions WHERE is_paper = true AND status = 'SETTLED') AS trade_count, (SELECT COUNT(*) >= 50 FROM positions WHERE is_paper = true AND status = 'SETTLED') AS trades_ok",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ]
}
